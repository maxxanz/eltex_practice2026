#!/bin/bash

CONFIG_FILE="observer.conf"
LOG_FILE="observer.log"

# Проверяем, существует ли файл конфигурации
if [ ! -f "$CONFIG_FILE" ]; then
    echo "Файл конфигурации $CONFIG_FILE не найден!" >> "$LOG_FILE"
    exit 1
fi

# Читаем файл конфигурации построчно
while IFS= read -r SCRIPT_PATH; do
    # Пропускаем пустые строки
    if [ -z "$SCRIPT_PATH" ]; then
        continue
    fi

    # Имя скрипта без пути (для поиска в /proc)
    SCRIPT_NAME=$(basename "$SCRIPT_PATH")

    # Проверяем, запущен ли этот скрипт.
    # Ищем в /proc/*/cmdline, чтобы найти процессы с нашим скриптом.
    # Используем grep -F для точного поиска строки.
    if pgrep -f "$SCRIPT_NAME" > /dev/null; then
        # Процесс запущен, ничего не делаем
        continue
    else
        # Процесс не запущен, запускаем его через nohup
        echo "$(date '+%Y-%m-%d %H:%M:%S') Запуск: $SCRIPT_PATH" >> "$LOG_FILE"
        # Запускаем в фоне с nohup, чтобы не зависеть от терминала
        nohup "$SCRIPT_PATH" > /dev/null 2>&1 &
    fi
done < "$CONFIG_FILE"



