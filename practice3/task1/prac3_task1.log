#!/bin/bash

# --- Настройки ---
PIPE_DIR="/tmp/run"          # Папка для канала
PIPE_NAME="cuckoo.pid"       # Имя файла канала
PIPE_PATH="$PIPE_DIR/$PIPE_NAME"
LOG_FILE="cuckoo.log"        # Файл для логов

# --- 1. Создаем папку и именованный канал (если их нет) ---
mkdir -p "$PIPE_DIR"
# Удаляем старый канал, если он есть, чтобы не было ошибок
rm -f "$PIPE_PATH"
mkfifo "$PIPE_PATH"

# --- 2. Записываем в лог сообщение о запуске ---
echo "$(date '+%Y-%m-%d %H:%M:%S') Startup!" >> "$LOG_FILE"

# --- 3. Функция, которая будет выполняться при получении сигнала ---
shutdown() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') Shutdown!" >> "$LOG_FILE"
    rm -f "$PIPE_PATH"  # Удаляем канал
    exit 0
}

# Ловим сигнал SIGUSR1 и вызываем функцию shutdown
trap shutdown SIGUSR1

# --- 4. Основной цикл: читаем запросы из канала ---
while true; do
    # Читаем одну строку из канала.
    # ВАЖНО: используем redirect на уровне цикла, а не на уровне read!
    if read -r request; then
        # Из запроса вида "bash[1234]: how much time do I have?"
        # нам нужно извлечь имя процесса и его PID.
        if [[ "$request" =~ ^([^\[]+)\[([0-9]+)\]: ]]; then
            NAME="${BASH_REMATCH[1]}"
            PID="${BASH_REMATCH[2]}"
        else
            # Если формат не распознан, пропускаем
            echo "Ошибка формата: $request" >> "$LOG_FILE"
            continue
        fi

        # Генерируем случайное число N от 2 до 10
        N=$(( (RANDOM % 9) + 2 ))

        # Отправляем ответ обратно в канал
        # ВАЖНО: просто echo (без перенаправления), потому что вывод идет в канал
        echo "$N"

        # Записываем событие в лог
        echo "$(date '+%Y-%m-%d %H:%M:%S') ${NAME}[${PID}] ${N}" >> "$LOG_FILE"
    fi
done < "$PIPE_PATH"   # <--- ВОТ ЗДЕСЬ! Весь цикл читает из канала




